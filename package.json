{
  "name": "message-unpacked",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "A static-first, open-source anti-fraud learning experience for classrooms.",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "dev": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "pnpm schema:check && pnpm validate:content && cross-env ASTRO_TELEMETRY_DISABLED=1 astro check && cross-env ASTRO_TELEMETRY_DISABLED=1 astro build",
    "build:subpath": "pnpm schema:check && pnpm validate:content && cross-env ASTRO_TELEMETRY_DISABLED=1 PUBLIC_ROOM_SERVICE_URL=https://rooms.example SITE_BASE=/message-unpacked/ SITE_URL=https://example.github.io astro check && cross-env ASTRO_TELEMETRY_DISABLED=1 PUBLIC_ROOM_SERVICE_URL=https://rooms.example SITE_BASE=/message-unpacked/ SITE_URL=https://example.github.io astro build",
    "check:subpath": "node scripts/check-static-build.mjs /message-unpacked/",
    "preview": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "cross-env ASTRO_TELEMETRY_DISABLED=1 astro check && tsc --noEmit",
    "worker:typecheck": "tsc --noEmit -p workers/tsconfig.json",
    "worker:dev": "cross-env WRANGLER_LOG_PATH=/tmp/message-unpacked-wrangler.log wrangler dev --config workers/wrangler.toml",
    "test": "vitest run",
    "test:worker": "vitest run --config vitest.worker.config.ts",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:a11y": "playwright test --grep @a11y",
    "schema:generate": "node --import tsx scripts/generate-case-schema.ts",
    "schema:check": "node --import tsx scripts/generate-case-schema.ts --check",
    "validate:content": "node --import tsx scripts/validate-content.ts",
    "license:check": "node scripts/check-licenses.mjs --check"
  },
  "dependencies": {
    "@astrojs/react": "6.0.1",
    "@phosphor-icons/react": "2.1.10",
    "@xstate/react": "6.1.0",
    "astro": "7.1.1",
    "qrcode.react": "4.2.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "xstate": "5.32.5",
    "yaml": "2.9.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@axe-core/playwright": "4.12.1",
    "@cloudflare/vitest-pool-workers": "0.18.6",
    "@cloudflare/workers-types": "5.20260714.1",
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@types/node": "^24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "cross-env": "10.1.0",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "17.7.0",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "prettier-plugin-astro": "0.14.1",
    "tsx": "4.23.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10",
    "wrangler": "4.112.0"
  }
}
