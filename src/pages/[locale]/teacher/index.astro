---
import TeacherPage from '../../../components/TeacherPage.astro';
import { locales, type Locale } from '../../../i18n/catalogs';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
---

<TeacherPage {locale} />
