---
import { getCollection } from 'astro:content';
import { ArrowLeftIcon, BookOpenIcon } from '@phosphor-icons/react/ssr';

import {
  ClassroomClicker,
  type ClickerCase,
} from '../../../../features/classroom/ClassroomClicker';
import type { Locale } from '../../../../i18n/catalogs';
import { locales } from '../../../../i18n/catalogs';
import {
  getCatalog,
  localeActivityPath,
  localeClassroomJoinPath,
  localePath,
  localeTeacherPath,
} from '../../../../i18n/locale';
import BaseLayout from '../../../../layouts/BaseLayout.astro';

export function getStaticPaths() {
  return locales.map((locale) => ({ params: { locale }, props: { locale } }));
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const catalog = getCatalog(locale);
const cases = await getCollection(
  'cases',
  ({ data }) => data.status === 'published' && data.locale === locale,
);
const roomServiceUrl = import.meta.env.PUBLIC_ROOM_SERVICE_URL;
const isRoomServiceConfigured =
  typeof roomServiceUrl === 'string' && roomServiceUrl.trim().length > 0;
const alternateLocale: Locale = locale === 'zh-TW' ? 'en' : 'zh-TW';
const clickerCases: ClickerCase[] = cases.map(({ data }) => ({
  id: data.id,
  contentVersion: data.contentVersion,
  choices: data.choices.map(({ id, label }) => ({ id, label })),
}));
---

<BaseLayout {catalog} {locale}>
  <header class="activity-site-header">
    <a class="brand" href={localePath(locale)} aria-label="Message, Unpacked.">
      <span class="brand-mark" aria-hidden="true">M.U.</span>
      <span>
        <strong>Message, Unpacked.</strong>
        <small>{catalog.nav.brandDescriptor}</small>
      </span>
    </a>
    <div class="activity-header-actions">
      <a class="activity-home-link" href={localeTeacherPath(locale)}>
        <ArrowLeftIcon aria-hidden="true" weight="bold" />
        {catalog.classroomShell.backToTeacher}
      </a>
      <div class="language-switch" aria-label={catalog.nav.language}>
        <span aria-current="page">{locale === 'zh-TW' ? '中文' : 'EN'}</span>
        <a
          href={localeClassroomJoinPath(alternateLocale)}
          hreflang={alternateLocale}
        >
          {locale === 'zh-TW' ? 'EN' : '中文'}
        </a>
      </div>
    </div>
  </header>

  <main id="main" class="activity-page-main" tabindex="-1">
    <section class="activity-page-intro" aria-labelledby="classroom-join-title">
      <div>
        <p class="eyebrow">{catalog.classroomShell.joinEyebrow}</p>
        <h1 id="classroom-join-title">{catalog.classroomShell.joinHeading}</h1>
        <p>{catalog.classroomShell.joinDescription}</p>
      </div>
    </section>
    <section class="activity-page-stage">
      {
        cases.length === 0 || !isRoomServiceConfigured ? (
          <div class="classroom-route-shell">
            <p>
              {cases.length === 0
                ? catalog.classroomShell.localeUnavailable
                : catalog.classroomShell.serviceUnconfigured}
            </p>
            {cases.length === 0 && (
              <a href={localeClassroomJoinPath('zh-TW')}>
                {catalog.classroomShell.switchToChinese}
              </a>
            )}
            <a href={localeActivityPath(locale)}>
              <BookOpenIcon aria-hidden="true" weight="bold" />
              {catalog.classroomShell.staticActivity}
            </a>
          </div>
        ) : (
          <ClassroomClicker
            client:load
            cases={clickerCases}
            {catalog}
            roomServiceUrl={roomServiceUrl.trim()}
          />
        )
      }
    </section>
  </main>
</BaseLayout>

<style>
  .classroom-route-shell {
    background: var(--brand-deep);
    border-radius: 0.9rem;
    color: white;
    display: grid;
    gap: 1rem;
    margin: 0 auto;
    max-width: 1424px;
    padding: clamp(1.4rem, 3vw, 2.4rem);
  }

  .classroom-route-shell p {
    line-height: 1.7;
    margin: 0;
  }

  .classroom-route-shell a {
    align-items: center;
    color: white;
    display: inline-flex;
    font-weight: 800;
    gap: 0.4rem;
    width: fit-content;
  }

  .classroom-route-shell svg {
    height: 1rem;
    width: 1rem;
  }
</style>
