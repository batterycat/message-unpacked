---
import { getCollection } from 'astro:content';
import {
  ArrowLeftIcon,
  BookOpenIcon,
  ShieldCheckIcon,
} from '@phosphor-icons/react/ssr';

import { loadResponseRegistry } from '../domain/resources/load';
import type { Locale } from '../i18n/catalogs';
import {
  getCatalog,
  localeActivityPath,
  localePath,
  localeTeacherPath,
} from '../i18n/locale';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ScenarioDemo } from './ScenarioDemo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const catalog = getCatalog(locale);
const caseEntries = await getCollection(
  'cases',
  ({ data }) => data.status === 'published' && data.locale === locale,
);
const scenarios = caseEntries
  .map((entry) => entry.data)
  .sort((left, right) => left.id.localeCompare(right.id));
const responseRegistry = await loadResponseRegistry(locale);
const alternateLocale: Locale = locale === 'zh-TW' ? 'en' : 'zh-TW';
---

<BaseLayout {catalog} {locale}>
  <header class="activity-site-header">
    <a class="brand" href={localePath(locale)} aria-label="Message, Unpacked.">
      <span class="brand-mark" aria-hidden="true">M.U.</span>
      <span>
        <strong>Message, Unpacked.</strong>
        <small>{catalog.nav.brandDescriptor}</small>
      </span>
    </a>
    <div class="activity-header-actions">
      <a class="activity-home-link" href={localePath(locale)}>
        <ArrowLeftIcon aria-hidden="true" weight="bold" />
        {catalog.activityPage.backHome}
      </a>
      <div class="language-switch" aria-label={catalog.nav.language}>
        <span aria-current="page">{locale === 'zh-TW' ? '中文' : 'EN'}</span>
        <a
          href={localeActivityPath(alternateLocale)}
          hreflang={alternateLocale}
        >
          {locale === 'zh-TW' ? 'EN' : '中文'}
        </a>
      </div>
    </div>
  </header>

  <main id="main" class="activity-page-main" tabindex="-1">
    <section class="activity-page-intro" aria-labelledby="activity-page-title">
      <div>
        <p class="eyebrow">{catalog.activityPage.eyebrow}</p>
        <h1 id="activity-page-title">{catalog.activityPage.heading}</h1>
        <p>{catalog.activityPage.description}</p>
      </div>
      <p class="activity-privacy-note">
        <ShieldCheckIcon aria-hidden="true" weight="fill" />
        {catalog.hero.note}
      </p>
    </section>

    <section id="demo" class="activity-page-stage">
      <ScenarioDemo
        client:load
        {catalog}
        {locale}
        resources={responseRegistry.resources}
        {scenarios}
        teacherSetupHref={localeTeacherPath(locale)}
        switchToChineseHref={`${localeActivityPath('zh-TW')}#demo`}
      />
    </section>
  </main>

  <footer class="activity-footer">
    <div class="footer-brand">
      <strong>Message, Unpacked.</strong>
      <span>{catalog.footer.statement}</span>
    </div>
    <a href={localePath(locale)}>
      <BookOpenIcon aria-hidden="true" weight="bold" />
      {catalog.activityPage.backHome}
    </a>
    <div class="license-list">
      <span>{catalog.footer.codeLicense}</span>
      <span>{catalog.footer.contentLicense}</span>
    </div>
  </footer>
</BaseLayout>
