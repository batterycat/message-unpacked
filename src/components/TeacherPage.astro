---
import { getCollection } from 'astro:content';
import {
  ArrowLeftIcon,
  ArrowSquareOutIcon,
  BookOpenIcon,
} from '@phosphor-icons/react/ssr';

import {
  localeClassroomHostPath,
  localeClassroomJoinPath,
  localeActivityPath,
  localePath,
  localeTeacherPath,
  getCatalog,
} from '../i18n/locale';
import { ClassroomEntry } from '../features/classroom/ClassroomEntry';
import type { Locale } from '../i18n/catalogs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { TeacherConfigurator } from './TeacherConfigurator';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const catalog = getCatalog(locale);
const teacherGuideHref = 'https://batterycat.gitbook.io/message-unpacked-docs/';
const usagePrivacyHref = `${teacherGuideHref}shi-yong-fan-wei-yin-si-yu-wai-bu-fu-wu`;
const caseEntries = await getCollection(
  'cases',
  ({ data }) => data.status === 'published' && data.locale === locale,
);
const scenarios = caseEntries
  .map((entry) => entry.data)
  .sort((left, right) => left.id.localeCompare(right.id));
const alternateLocale: Locale = locale === 'zh-TW' ? 'en' : 'zh-TW';
const roomServiceUrl = import.meta.env.PUBLIC_ROOM_SERVICE_URL;
const isRoomServiceConfigured =
  typeof roomServiceUrl === 'string' && roomServiceUrl.trim().length > 0;
---

<BaseLayout {catalog} {locale}>
  <header class="activity-site-header">
    <a class="brand" href={localePath(locale)} aria-label="Message, Unpacked.">
      <span class="brand-mark" aria-hidden="true">M.U.</span>
      <span>
        <strong>Message, Unpacked.</strong>
        <small>{catalog.nav.brandDescriptor}</small>
      </span>
    </a>
    <div class="activity-header-actions">
      <a class="activity-home-link" href={localePath(locale)}>
        <ArrowLeftIcon aria-hidden="true" weight="bold" />
        {catalog.teacherPage.backHome}
      </a>
      <div class="language-switch" aria-label={catalog.nav.language}>
        <span aria-current="page">{locale === 'zh-TW' ? '中文' : 'EN'}</span>
        <a href={localeTeacherPath(alternateLocale)} hreflang={alternateLocale}>
          {locale === 'zh-TW' ? 'EN' : '中文'}
        </a>
      </div>
    </div>
  </header>

  <main id="main" class="teacher-page-main" tabindex="-1">
    <section class="teacher-page-intro" aria-labelledby="teacher-page-title">
      <div>
        <p class="eyebrow">{catalog.teacherPage.eyebrow}</p>
        <h1 id="teacher-page-title">{catalog.teacherPage.heading}</h1>
        <p>{catalog.teacherPage.description}</p>
      </div>
      <div class="teacher-page-links">
        <a class="teacher-page-exercise-link" href={localeActivityPath(locale)}>
          <BookOpenIcon aria-hidden="true" weight="bold" />
          {catalog.activityPage.heading}
        </a>
        <a
          class="teacher-page-guide-link"
          href={teacherGuideHref}
          target="_blank"
          rel="noreferrer"
        >
          <BookOpenIcon aria-hidden="true" weight="bold" />
          {catalog.teacherPage.teacherGuide}
          <ArrowSquareOutIcon aria-hidden="true" weight="bold" />
        </a>
      </div>
    </section>

    <section
      class="teacher-page-configurator"
      aria-label={catalog.nav.teacherArea}
    >
      <TeacherConfigurator
        client:load
        {catalog}
        {locale}
        {scenarios}
        activityPath={localeActivityPath(locale)}
      />
    </section>

    <section
      class="teacher-page-classroom"
      aria-label={catalog.classroomEntry.heading}
    >
      <ClassroomEntry
        {catalog}
        hasReviewedCases={scenarios.length > 0}
        hostPath={localeClassroomHostPath(locale)}
        isServiceConfigured={isRoomServiceConfigured}
        joinPath={localeClassroomJoinPath(locale)}
        switchLocaleHostPath={localeClassroomHostPath('zh-TW')}
      />
    </section>
  </main>

  <footer class="activity-footer">
    <div class="footer-brand">
      <strong>Message, Unpacked.</strong>
      <span>{catalog.footer.statement}</span>
    </div>
    <nav aria-label={catalog.nav.about}>
      <a href={localePath(locale)}>
        <ArrowLeftIcon aria-hidden="true" weight="bold" />
        {catalog.teacherPage.backHome}
      </a>
      <a href={teacherGuideHref}>{catalog.footer.teacherGuide}</a>
      <a href={usagePrivacyHref}>{catalog.footer.usagePrivacy}</a>
    </nav>
    <div class="license-list">
      <span>{catalog.footer.codeLicense}</span>
      <span>{catalog.footer.contentLicense}</span>
    </div>
  </footer>
</BaseLayout>

<style>
  .teacher-page-classroom {
    padding: 0 clamp(1rem, 3vw, 2.5rem) 3.25rem;
  }

  @media (max-width: 700px) {
    .teacher-page-classroom {
      padding-inline: 0;
    }
  }
</style>
