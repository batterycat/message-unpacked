---
import { getCollection } from 'astro:content';
import {
  ArrowSquareOutIcon,
  BookOpenIcon,
  CodeIcon,
  GraduationCapIcon,
  MagnifyingGlassIcon,
  ShieldCheckIcon,
  UsersThreeIcon,
} from '@phosphor-icons/react/ssr';

import { loadResponseRegistry } from '../domain/resources/load';
import {
  getCatalog,
  localePath,
  localeTeacherPath,
  teacherGuidePrivacyUrl,
  teacherGuideUrl,
} from '../i18n/locale';
import type { Locale } from '../i18n/catalogs';
import BaseLayout from '../layouts/BaseLayout.astro';
import { ScenarioDemo } from './ScenarioDemo';

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const catalog = getCatalog(locale);
const caseEntries = await getCollection(
  'cases',
  ({ data }) => data.status === 'published' && data.locale === locale,
);
const allScenarios = caseEntries
  .map((entry) => entry.data)
  .sort((left, right) => left.id.localeCompare(right.id));
const homepageScenarioGroups = [
  'delivery-address',
  'dm-friend-crisis',
  'bank-security-call',
];
const curatedScenarios = homepageScenarioGroups.flatMap((translationGroupId) =>
  allScenarios.filter(
    (scenario) => scenario.translationGroupId === translationGroupId,
  ),
);
const curatedScenarioIds = new Set(
  curatedScenarios.map((scenario) => scenario.id),
);
const scenarios = [
  ...curatedScenarios,
  ...allScenarios.filter((scenario) => !curatedScenarioIds.has(scenario.id)),
].slice(0, homepageScenarioGroups.length);
const responseRegistry = await loadResponseRegistry(locale);
const alternateLocale: Locale = locale === 'zh-TW' ? 'en' : 'zh-TW';
const heroImagePath = `${import.meta.env.BASE_URL}assets/hero-message-check.png`;
const teacherGuideHref = teacherGuideUrl(locale);
const repositoryHref = 'https://github.com/batterycat/message-unpacked';
const usagePrivacyHref = teacherGuidePrivacyUrl(locale);
---

<BaseLayout {catalog} {locale}>
  <header class="site-header">
    <a class="brand" href={localePath(locale)} aria-label="Message, Unpacked.">
      <span class="brand-mark" aria-hidden="true">M.U.</span>
      <span>
        <strong>Message, Unpacked.</strong>
        <small>{catalog.nav.brandDescriptor}</small>
      </span>
    </a>
    <nav aria-label={catalog.nav.primary}>
      <a href="#demo"
        ><BookOpenIcon aria-hidden="true" weight="bold" />{
          catalog.nav.learningChallenge
        }</a
      >
      <a href={localeTeacherPath(locale)}
        ><GraduationCapIcon aria-hidden="true" weight="bold" />{
          catalog.nav.teacherArea
        }</a
      >
      <a href={repositoryHref}
        ><UsersThreeIcon aria-hidden="true" weight="bold" />{
          catalog.nav.contribute
        }</a
      >
    </nav>
    <div class="language-switch" aria-label={catalog.nav.language}>
      <span aria-current="page">{locale === 'zh-TW' ? '中文' : 'EN'}</span>
      <a href={localePath(alternateLocale)} hreflang={alternateLocale}>
        {locale === 'zh-TW' ? 'EN' : '中文'}
      </a>
    </div>
  </header>

  <main id="main" tabindex="-1">
    <section class="hero">
      <div class="hero-copy">
        <p class="eyebrow">{catalog.hero.eyebrow}</p>
        <h1 aria-label={catalog.hero.title}>
          <span aria-hidden="true">{catalog.hero.titleLineOne}</span>
          <span aria-hidden="true">{catalog.hero.titleLineTwo}</span>
        </h1>
        <p class="hero-description">{catalog.hero.description}</p>
        <div class="hero-actions">
          <a class="button button-primary" href="#demo">
            <BookOpenIcon aria-hidden="true" weight="bold" />
            {catalog.hero.start}
          </a>
          <a class="button button-secondary" href={localeTeacherPath(locale)}>
            <UsersThreeIcon aria-hidden="true" weight="bold" />
            {catalog.hero.teacher}
          </a>
        </div>
        <p class="hero-note">
          <ShieldCheckIcon aria-hidden="true" weight="fill" />
          {catalog.hero.note}
        </p>
      </div>
      <div class="hero-art">
        <img
          src={heroImagePath}
          alt=""
          width="1672"
          height="942"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </section>

    <section class="learning-path" aria-labelledby="learning-path-title">
      <MagnifyingGlassIcon aria-hidden="true" weight="duotone" />
      <div>
        <strong id="learning-path-title">{catalog.learningPath.title}</strong>
        <span>{catalog.learningPath.summary}</span>
      </div>
    </section>

    <section id="demo" class="demo-section">
      <ScenarioDemo
        client:load
        {catalog}
        {locale}
        resources={responseRegistry.resources}
        {scenarios}
        teacherSetupHref={localeTeacherPath(locale)}
      />
    </section>

    <section id="teacher" class="teacher-section">
      <div class="teacher-callout">
        <div>
          <p class="eyebrow">{catalog.teacherSetup.eyebrow}</p>
          <h2>{catalog.modes.teacherTitle}</h2>
          <p>{catalog.modes.teacherDescription}</p>
        </div>
        <a class="button button-primary" href={localeTeacherPath(locale)}>
          <GraduationCapIcon aria-hidden="true" weight="bold" />
          {catalog.hero.teacher}
        </a>
      </div>
    </section>

    <section class="resource-section" aria-label={catalog.nav.about}>
      <a class="resource-card" href={teacherGuideHref}>
        <BookOpenIcon aria-hidden="true" weight="duotone" />
        <div>
          <p>{catalog.homeLinks.guideLabel}</p>
          <h2>{catalog.homeLinks.guideTitle}</h2>
          <span>{catalog.homeLinks.guideDescription}</span>
          <strong>{catalog.homeLinks.guideAction}</strong>
        </div>
        <ArrowSquareOutIcon aria-hidden="true" weight="bold" />
      </a>
      <a class="resource-card" href={repositoryHref}>
        <CodeIcon aria-hidden="true" weight="duotone" />
        <div>
          <p>{catalog.homeLinks.contributeLabel}</p>
          <h2>{catalog.homeLinks.contributeTitle}</h2>
          <span>{catalog.homeLinks.contributeDescription}</span>
          <strong>{catalog.homeLinks.contributeAction}</strong>
        </div>
        <ArrowSquareOutIcon aria-hidden="true" weight="bold" />
      </a>
    </section>
  </main>

  <footer>
    <div class="footer-brand">
      <strong>Message, Unpacked.</strong>
      <span>{catalog.footer.statement}</span>
    </div>
    <nav aria-label={catalog.nav.about}>
      <a href={localeTeacherPath(locale)}>{catalog.nav.teacherArea}</a>
      <a href={teacherGuideHref}>{catalog.footer.teacherGuide}</a>
      <a href={repositoryHref}>{catalog.footer.repository}</a>
      <a href={usagePrivacyHref}>{catalog.footer.usagePrivacy}</a>
    </nav>
    <div class="license-list">
      <span>{catalog.footer.codeLicense}</span>
      <span>{catalog.footer.contentLicense}</span>
    </div>
  </footer>
</BaseLayout>
